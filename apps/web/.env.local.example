# Database
DATABASE_URI=postgresql://user:password@localhost:5432/wandererdiary
PAYLOAD_SECRET=your-32-char-secret-key-here

# App
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Media Storage (Cloudflare R2 / S3)
R2_BUCKET=wandererdiary-media
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.wandererdiary.com

# Search
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-master-key

# Cache / Queue
REDIS_URL=redis://localhost:6379

# Email
RESEND_API_KEY=re_...
